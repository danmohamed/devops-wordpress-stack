# MySQL root password (used for admin-level DB access)
MYSQL_ROOT_PASSWORD=change_me_root_password

# Database WordPress will use
MYSQL_DATABASE=wordpress_db

# Dedicated WordPress DB user (do not use root for the app connection)
MYSQL_USER=wordpress_user
MYSQL_PASSWORD=change_me_user_password

# Optional: domain used for the site (helps avoid siteurl/home mismatches)
SITE_DOMAIN=localhost
